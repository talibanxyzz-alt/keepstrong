{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "instrumentation.ts",
    "instrumentation-client.ts",
    "middleware.ts",
    "scripts/**/*.ts"
  ],
  "project": ["**/*.{ts,tsx}"],
  "ignore": [
    "**/*.test.ts",
    "**/*.spec.ts",
    "tests/**",
    "types/database.types.ts"
  ],
  "ignoreDependencies": ["sharp", "supabase"]
}
