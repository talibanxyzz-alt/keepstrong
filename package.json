{
  "name": "glp-1-fitness-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 0.0.0.0",
    "dev:localhost": "next dev",
    "dev:clean": "rm -rf .next && next dev --hostname 0.0.0.0",
    "dev:turbo": "next dev --hostname 0.0.0.0 --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "cache:clear": "rm -rf .next",
    "clean:all": "rm -rf .next node_modules .turbo",
    "fresh:install": "rm -rf .next node_modules package-lock.json && npm install",
    "seed:workouts": "tsx scripts/seed-workouts.ts",
    "verify:upstash": "tsx scripts/verify-upstash-redis.ts",
    "analyze": "ANALYZE=true next build",
    "lighthouse": "lighthouse http://localhost:3000 --view --preset=desktop",
    "type-check": "tsc --noEmit",
    "predeploy": "npm run type-check && npm run lint && npm run test && npm run build",
    "predeploy:e2e": "npm run predeploy && npm run test:e2e:smoke",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=chromium --grep \"Production smoke\"",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@react-email/components": "^1.0.6",
    "@sentry/nextjs": "^10.38.0",
    "@stripe/stripe-js": "^4.10.0",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "2.49.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^1.4.1",
    "canvas-confetti": "^1.9.3",
    "critters": "^0.0.23",
    "date-fns": "^4.1.0",
    "expo": "^55.0.10-canary-20260328-2049187",
    "lucide-react": "^0.468.0",
    "next": "16.2.1",
    "next-pwa": "^5.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-email": "^5.2.5",
    "recharts": "^2.15.0",
    "resend": "^4.0.3",
    "sharp": "^0.33.5",
    "sonner": "^1.7.2",
    "stripe": "^17.5.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@types/canvas-confetti": "^1.6.4",
    "@types/node": "^20",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "^4.1.1",
    "dotenv": "^16.4.7",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8",
    "supabase": "^2.64.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "tar": "^7.5.7",
    "node-fetch": "2.7.0",
    "serialize-javascript": "^7.0.5"
  }
}
