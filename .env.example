# -----------------------------------------------------------------------------
# Validation (see lib/env.ts)
# - Local dev: Supabase + NEXT_PUBLIC_APP_URL are required.
# - Production builds: Stripe + price IDs + webhook secret are also required.
# - Set CRON_SECRET in production so scheduled emails are not left publicly callable.
# -----------------------------------------------------------------------------

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe Configuration (use test keys for development)
# Get these from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Webhook Secret
# Get this from Stripe CLI: stripe listen --forward-to localhost:3000/api/stripe/webhook
# Or from Stripe Dashboard for production
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs
# Create products and prices in Stripe Dashboard
# Copy the price IDs (start with "price_")
STRIPE_CORE_PRICE_ID=price_core_plan_id_here
STRIPE_PREMIUM_PRICE_ID=price_premium_plan_id_here

# Application URL (must match the origin users open in the browser)
# Development on this machine: http://localhost:3000
# Phone on same Wi‑Fi: http://YOUR_COMPUTER_LAN_IP:3000 (e.g. http://192.168.1.4:3000) — not "localhost" on the phone
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase → Authentication → URL Configuration:
# - Site URL: match NEXT_PUBLIC_APP_URL when testing (use LAN URL for phone dev).
# - Redirect URLs: add http://localhost:3000/auth/callback AND http://<LAN-IP>:3000/auth/callback

# Email: signed unsubscribe links (HMAC). Falls back to CRON_SECRET if unset.
# In production, set one of these so plain ?user_id= unsubscribe URLs are rejected.
EMAIL_UNSUBSCRIBE_SECRET=your_long_random_secret_here

# Cron / scheduled jobs (Vercel Cron, etc.)
CRON_SECRET=your_cron_bearer_token_here

# Optional: Upstash Redis — API rate limits (meal photo AI, uploads, email send, export/delete)
# https://console.upstash.com/ → create Redis → REST URL + token
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: Expo Push API (https://expo.dev/accounts/[account]/settings/access-tokens)
# Used by lib/send-expo-push.ts when sending from cron or API routes. Many small sends work without it.
# EXPO_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Playwright E2E — production smoke (optional)
# -----------------------------------------------------------------------------
# Copy this file to .env.local and fill values. playwright.config.ts loads .env.local.
#
# Or export in your shell before running tests (overrides for that session only):
#
#   export PLAYWRIGHT_PRODUCTION_URL="https://YOUR_PROJECT.vercel.app"
#   export PLAYWRIGHT_SKIP_WEBSERVER=1
#   export TEST_USER_EMAIL="your-test@email.com"
#   export TEST_USER_PASSWORD="your-test-password"
#   npx playwright test --project=chromium --grep "Production smoke"
#
# PLAYWRIGHT_PRODUCTION_URL — deployed app origin (omit to use localhost).
# PLAYWRIGHT_SKIP_WEBSERVER=1 — do not start npm run dev (required when using production URL).
# TEST_USER_* — fully onboarded account; required for /settings smoke tests (otherwise skipped).

# PLAYWRIGHT_PRODUCTION_URL=https://YOUR_PROJECT.vercel.app
# PLAYWRIGHT_SKIP_WEBSERVER=1
# TEST_USER_EMAIL=your-test@email.com
# TEST_USER_PASSWORD=your-test-password
